# CSES MCP Server Environment Configuration
# Copy this file to .env and customize the values

# Server Configuration
SERVER_NAME=cses-mcp
SERVER_VERSION=0.1.0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/cses-mcp.log

# Feature Flags
ENABLE_DEBUG=false

# CSES Configuration
CSES_BASE_URL=https://cses.fi
REQUEST_TIMEOUT=30

# PHPSESSID Cookie
PHPSESSID=abcdefgxyz123456789